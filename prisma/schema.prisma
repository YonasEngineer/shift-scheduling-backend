// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                  @id @default(uuid())
  firstName               String                  @map("first_name")
  lastName                String                  @map("last_name")
  email                   String                  @unique
  passwordHash            String                  @map("password_hash")
  role                    Role
  isActive                Boolean                 @default(true) @map("is_active")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  userLocations           UserLocation[]
  userSkills              UserSkill[]
  recurringAvailabilities AvailabilityRecurring[]
  availabilityExceptions  AvailabilityException[]
  shifts                  Shifts[]
  shiftAssignments        ShiftAssignments[]
  requestedSwaps          SwapRequests[]          @relation("SwapRequester")
  targetedSwaps           SwapRequests[]          @relation("SwapTarget")
  workLogs                WorkLogs[]
  notifications           Notifications[]
  userPreferences         UserPreferences?
  auditLogs               AuditLogs[]
  schedules               Schedule[]
  userWeeklyStats         UserWeeklyStats[]

  @@map("users")
}

model UserLocation {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  locationId  String           @map("location_id")
  role        UserLocationRole
  isCertified Boolean?         @default(false) @map("is_certified")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  user        User             @relation(fields: [userId], references: [id])
  location    Location         @relation(fields: [locationId], references: [id])

  @@unique([userId, locationId])
  @@map("user_locations")
}

model Location {
  id            String         @id @default(uuid())
  name          String
  timezone      String
  address       String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  // Relations (optional, if you already have UserLocation)
  userLocations UserLocation[]
  shifts        Shifts[]
  schedules     Schedule[]

  @@map("locations")
}

model Skill {
  id         String      @id @default(uuid())
  name       String      @unique
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  userSkills UserSkill[]
  shifts     Shifts[]

  @@map("skills")
}

model UserSkill {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  skillId   String   @map("skill_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  // Relations
  user      User     @relation(fields: [userId], references: [id])
  skill     Skill    @relation(fields: [skillId], references: [id])

  @@map("user_skills")
}

model AvailabilityRecurring {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  dayOfWeek Int      @map("day_of_week")
  // startTime DateTime @map("start_time") @db.Time
  // endTime   DateTime @map("end_time") @db.Time
  startTime String
  endTime   String
  timezone  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("availability_recurring")
}

model AvailabilityException {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime
  // timezone    String // we need time zone
  // startTime   DateTime @db.Time
  // endTime     DateTime @db.
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("availability_exception")
}

model Shifts {
  id                String             @id @default(uuid())
  locationId        String
  startTime         DateTime           @db.Timestamptz
  endTime           DateTime           @db.Timestamptz
  requiredSkillId   String
  requiredHeadcount Int
  createdBy         String
  status            ShiftStatus        @default(DRAFT)
  isPremium         Boolean            @default(false)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  scheduleId        String?
  schedule          Schedule?          @relation(fields: [scheduleId], references: [id])
  location          Location           @relation(fields: [locationId], references: [id])
  requiredSkill     Skill              @relation(fields: [requiredSkillId], references: [id])
  creator           User               @relation(fields: [createdBy], references: [id])
  shiftAssignments  ShiftAssignments[]
  swapRequests      SwapRequests[]
  workLogs          WorkLogs[]

  @@index([locationId, startTime])
  @@map("shifts")
}

model Schedule {
  id                 String         @id @default(uuid())
  locationId         String
  weekStart          DateTime
  status             ScheduleStatus @default(DRAFT)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  createdBy          String
  publishCutoffHours Int            @default(48)
  location           Location       @relation(fields: [locationId], references: [id])
  creator            User           @relation(fields: [createdBy], references: [id])
  shifts             Shifts[]
}

model ShiftAssignments {
  id      String           @id @default(uuid())
  shiftId String
  userId  String
  status  AssignmentStatus @default(ASSIGNED)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  shift     Shifts   @relation(fields: [shiftId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([shiftId, userId]) // prevent duplicate assignment
  @@index([userId, status])
  @@map("shift_assignments")
}

model SwapRequests {
  id              String            @id @default(uuid())
  shiftId         String
  requesterId     String
  targetUserId    String?
  type            SwapRequestType
  status          SwapRequestStatus @default(PENDING)
  managerStatus   SwapManagerStatus @default(PENDING)
  expiresAt       DateTime? //  You’ll need a cron job / worker  Automatically set: status = EXPIRED   When expiresAt < now()
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  // approvedBy    String?
  // approvedAt    DateTime?
  // Neutral "Decision" fields
  processedById   String?           @map("processed_by_id")
  processedAt     DateTime?         @map("processed_at")
  rejectionReason String?           @map("rejection_reason") // Critical for staff morale!
  shift           Shifts            @relation(fields: [shiftId], references: [id])
  requester       User              @relation("SwapRequester", fields: [requesterId], references: [id])
  targetUser      User?             @relation("SwapTarget", fields: [targetUserId], references: [id])

  @@index([status, expiresAt])
  @@map("swap_requests")
}

model UserWeeklyStats {
  id            String   @id @default(uuid())
  userId        String
  weekStart     DateTime
  totalHours    Float
  overtimeHours Float
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
}

model WorkLogs {
  id        String    @id @default(uuid())
  userId    String
  shiftId   String
  clockIn   DateTime  @db.Timestamptz
  clockOut  DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id])
  shift     Shifts    @relation(fields: [shiftId], references: [id])

  @@unique([userId, shiftId]) // one log per shift per user
  @@index([userId, clockIn])
  @@map("work_logs")
}

model AuditLogs {
  id          String      @id @default(uuid())
  entityType  EntityType
  entityId    String
  action      AuditAction
  beforeData  Json?
  afterData   Json?
  // ipAddress   String?
  performedBy String
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  user        User        @relation(fields: [performedBy], references: [id])

  @@index([entityType, entityId])
  @@index([performedBy, createdAt])
  @@map("audit_logs")
}

model Notifications {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  metadata  Json?
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model UserPreferences {
  id                  String   @id @default(uuid())
  userId              String   @unique
  desiredHoursPerWeek Int
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

enum NotificationType {
  SHIFT_ASSIGNED
  SHIFT_REMINDER
  SWAP_REQUEST
  SWAP_ACCEPTED
  SWAP_REJECTED
  GENERAL
}

enum EntityType {
  SHIFT
  ASSIGNMENT
  SWAP
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum UserLocationRole {
  MANAGER
  STAFF
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum AssignmentStatus {
  ASSIGNED
  PENDING_SWAP
  PENDING_DROPPED
  COMPLETED_SWAP
  COMPLETED_DROPPED
  // CANCELLED
}

enum SwapRequestType {
  SWAP
  DROP
}

enum SwapRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum SwapManagerStatus {
  PENDING
  APPROVED
  REJECTED
}
